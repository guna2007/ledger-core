# =============================================================================
# Smart Bank Management System — Environment Variables
# =============================================================================
# Copy this file to .env in the same directory and fill in your values:
#   cp .env.example .env
# Render sets these via its dashboard; the .env file is for local dev only.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────
# MySQL JDBC connection URL.
# Render: use the connection string from your Render MySQL service.
DB_URL=jdbc:mysql://localhost:3306/smart_bank

# MySQL username.
DB_USERNAME=root

# MySQL password.
DB_PASSWORD=1234

# HikariCP maximum pool size (default: 10).
DB_POOL_SIZE=10

# ── SMTP (Email) ──────────────────────────────────────────────────────────
# SMTP server hostname.
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL).
SMTP_PORT=587

# SMTP username (usually your full email address).
SMTP_USERNAME=dev@smartbank.com

# SMTP password or app-specific password.
# For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
SMTP_PASSWORD=dev

# ── JWT ───────────────────────────────────────────────────────────────────
# HMAC-SHA256 secret key (must be at least 32 characters / 256 bits).
# Generate a strong one: openssl rand -base64 48
JWT_SECRET=SmartBankDevSecretKey2024ForJWTTokenGeneration

# JWT token expiration in milliseconds (default: 86400000 = 24 hours).
JWT_EXPIRATION_MS=86400000

# ── Server ────────────────────────────────────────────────────────────────
# Application HTTP port.
# Render sets PORT automatically; local dev defaults to 8080.
PORT=8080

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Render: set this to your frontend URL (e.g., https://bank-frontend.vercel.app).
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
